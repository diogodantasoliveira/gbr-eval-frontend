# gbr-eval-frontend environment variables
# Copy to .env.local and fill in values.

# ---- Server port (fixed) ----
# The frontend always runs on 3002. Do NOT change without updating docs/PORTS.md.
# Both `pnpm dev` and `pnpm start` pass -p 3002 explicitly in package.json.
PORT=3002

# ---- Database ----
# SQLite file path. Local default is ./gbr-eval.db in the project root.
DATABASE_URL=./gbr-eval.db

# ---- API authentication ----
# The /api/* routes require a bearer token in x-admin-token header.
# Generate with: openssl rand -hex 32
# If unset and DISABLE_AUTH is not "true", all /api/* requests return 503.
ADMIN_API_TOKEN=

# Local development only. When true AND NODE_ENV=development, bypasses
# ADMIN_API_TOKEN check. Do NOT set in staging/production.
DISABLE_AUTH=true

# ---- Rate limiting ----
# Maximum requests per IP per 60-second window (default 100).
RATE_LIMIT_MAX=100

# ---- CI webhook (run ingestion) ----
# POST /api/runs/webhook authenticates via Authorization: Bearer <WEBHOOK_SECRET>.
# If unset, the endpoint returns 503. Generate with: openssl rand -hex 32
# This is independent of ADMIN_API_TOKEN — the webhook has its own auth.
WEBHOOK_SECRET=
